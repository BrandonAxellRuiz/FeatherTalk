# FeatherTalk — Environment Variables
# Copy to .env and adjust values as needed.
# Env vars override settings.json when set.

# ── Audio ────────────────────────────────────────────────────────────
# Set to "stub" to skip real microphone capture (useful for testing)
# FEATHERTALK_AUDIO_MODE=stub

# Path to ffmpeg binary (default: "ffmpeg" from PATH)
# FEATHERTALK_FFMPEG_PATH=/usr/local/bin/ffmpeg

# ── ASR (Parakeet) ──────────────────────────────────────────────────
# URL of the Parakeet ASR worker /transcribe endpoint
# FEATHERTALK_ASR_URL=http://127.0.0.1:8787/transcribe

# ── Llama (cleanup LLM) ─────────────────────────────────────────────
# Ollama model to use for transcript cleanup
# Recommended:  qwen2.5:3b  (fast, bilingual, 1.9 GB)
# Alternative:  llama3.1:8b (higher quality, 4.9 GB)
# FEATHERTALK_LLAMA_MODEL=qwen2.5:3b

# Ollama API base URL
# FEATHERTALK_OLLAMA_URL=http://127.0.0.1:11434

# llama.cpp server base URL (only when llamaBackend = "llama.cpp")
# FEATHERTALK_LLAMA_CPP_URL=http://127.0.0.1:8080

# Command to launch Ollama if not running (default: "ollama")
# FEATHERTALK_OLLAMA_COMMAND=ollama
